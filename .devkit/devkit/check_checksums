set -o errexit
set -o nounset

function usage() {
  declare -r -i exitval=${1-1}
  cat <<USAGE
usage: $(basename "${BASH_SOURCE[0]}") [-h] [-u]

Verifies file integrity by checking SHA-256 checksums against a 'checksums.txt' file.
Every line in the checksums.txt file is generated by running 'sha256sum' on a file and appending the output.

options:
  -h, --help            Show this help message and exit.
  -u, --update          Update checksums in checksums.txt in place, preserving comments.
USAGE
  exit ${exitval}
}

declare -i UPDATE_MODE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help) usage 0 ;;
    -u | --update) UPDATE_MODE=1; shift ;;
    *) printf "Error: unrecognized arg: %s\n" "$1"; usage 1 ;;
  esac
done

DEVKIT="$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")"
readonly DEVKIT

readonly SCRIPTS="${DEVKIT}/../scripts"

source "${SCRIPTS}/lib_logging.sh"

# ANSI Color Codes
declare -r GREEN='\033[0;32m'
declare -r RED='\033[0;31m'
declare -r ORANGE='\033[0;33m'
declare -r NC='\033[0m' # No Color

if [[ ! -f "checksums.txt" ]]; then
  printf "%bError: checksums.txt not found.%b\n" "${RED}" "${NC}" &>/dev/stderr
  exit 1
fi

# Read preprocessed lines into an array to avoid multiple sed executions
mapfile -t lines < <(sed -e 's/#.*//' -e '/^[[:space:]]*$/d' checksums.txt)

if [[ ${#lines[@]} -eq 0 ]]; then
  if [[ ${UPDATE_MODE} -eq 1 ]]; then
    printf "%bNo files to update. The checksums.txt is empty or only contains whitespace.%b\n" "${ORANGE}" "${NC}"
  else
    printf "%bNo files to verify. The checksums.txt is empty or only contains whitespace.%b\n" "${ORANGE}" "${NC}"
  fi
  exit 0
fi

function verify_checksums() {
  declare -i ALL_OK=1

  for line in "${lines[@]}"; do
    # Split using double space as IFS
    IFS='  ' read -r expected_checksum filename <<< "${line}"

    # Skip empty lines or lines without two fields
    if [[ -z ${filename} ]]; then
      continue
    fi
    printf "Verifying checksum for %s ... " "${filename}"
    if [[ ! -f "${filename}" ]]; then
      echo -e "${RED}MISSING${NC}"
      ALL_OK=0
      continue
    fi
    actual_checksum=$(sha256sum "${filename}" | awk '{print $1}')
    if [[ "${actual_checksum}" == "${expected_checksum}" ]]; then
      echo -e "${GREEN}OK${NC}"
    else
      echo -e "${RED}FAILED${NC}"
      echo "  Expected: ${expected_checksum}"
      echo "  Actual:   ${actual_checksum}"
      ALL_OK=0
    fi
  done

  if [[ ${ALL_OK} -eq 1 ]]; then
    echo -e "${GREEN}All checksums verified successfully.${NC}"
    exit 0
  else
    echo -e "${RED}Checksums verification failed.${NC}"
    exit 1
  fi
}

function update_checksums() {
  local temp_file
  temp_file=$(mktemp)
  declare -i UPDATED_COUNT=0
  declare -i ERRORS=0

  # Use IFS= to preserve leading/trailing whitespace of the line
  while IFS= read -r line || [[ -n "${line}" ]]; do
    if [[ "${line}" =~ ^[[:space:]]*# ]] || [[ -z "${line}" ]]; then
      echo "${line}" >> "${temp_file}"
      continue
    fi

    clean_line="${line%%#*}"
    clean_line_trimmed="${clean_line#"${clean_line%%[![:space:]]*}"}"
    clean_line_trimmed="${clean_line_trimmed%"${clean_line_trimmed##*[![:space:]]}"}"

    if [[ -z "${clean_line_trimmed}" ]]; then
      echo "${line}" >> "${temp_file}"
      continue
    fi

    IFS='  ' read -r expected_checksum filename <<< "${clean_line_trimmed}"

    if [[ -z ${filename} ]]; then
      echo "${line}" >> "${temp_file}"
      continue
    fi

    if [[ ! -f "${filename}" ]]; then
      printf "%bError: file not found: %s%b\n" "${RED}" "${filename}" "${NC}" >&2
      ERRORS+=1
      echo "${line}" >> "${temp_file}"
      continue
    fi

    printf "Updating checksum for %s ... " "${filename}"
    new_checksum=$(sha256sum "${filename}" | awk '{print $1}')

    if [[ "${new_checksum}" != "${expected_checksum}" ]]; then
      updated_line="${line/${expected_checksum}/${new_checksum}}"
      echo "${updated_line}" >> "${temp_file}"
      echo -e "${GREEN}UPDATED${NC}"
      UPDATED_COUNT+=1
    else
      echo "${line}" >> "${temp_file}"
      echo -e "${NC}UNCHANGED${NC}"
    fi

  done < checksums.txt

  if [[ ${ERRORS} -gt 0 ]]; then
    printf "%bFailed to update some checksums due to errors.%b\n" "${RED}" "${NC}" >&2
    rm -f "${temp_file}"
    exit 1
  fi

  if [[ ${UPDATED_COUNT} -gt 0 ]]; then
    mv "${temp_file}" checksums.txt
    echo -e "${GREEN}Successfully updated ${UPDATED_COUNT} checksum(s).${NC}"
  else
    rm -f "${temp_file}"
    echo -e "${NC}All checksums are already up-to-date.${NC}"
  fi
}

if [[ ${UPDATE_MODE} -eq 1 ]]; then
  update_checksums
else
  verify_checksums
fi
