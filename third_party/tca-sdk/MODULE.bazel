module(
    name = "tca-sdk",
    version = "0.0.1",
)

bazel_dep(name = "toolchains_llvm", version = "1.4.0", dev_dependency = True)

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_archive(
    name = "confidential-federated-compute",
    build_file_content = """
filegroup(
  name = "sysroot",
  srcs = glob(["*/**"]),
  visibility = ["//visibility:public"],
)
""",
    dev_dependency = True,
    sha256 = "f58c289b3ccb28895ad8ca408ac366e709037088e8b5c28aca18212adc18c31e",
    urls = ["https://github.com/google-parfait/confidential-federated-compute/releases/download/sysroot-20250618/sysroot.tar.xz"],
)

llvm = use_extension("@toolchains_llvm//toolchain/extensions:llvm.bzl", "llvm", dev_dependency = True)
llvm.toolchain(
    name = "llvm_toolchain_with_custom_sysroot",
    llvm_version = "20.1.0",
)
llvm.sysroot(
    name = "llvm_toolchain_with_custom_sysroot",
    label = "@confidential-federated-compute//:sysroot",
    targets = ["linux-x86_64"],
)
use_repo(llvm, "llvm_toolchain_with_custom_sysroot")

register_toolchains(
    "@llvm_toolchain_with_custom_sysroot//:all",
    dev_dependency = True,
)

bazel_dep(name = "rules_cc", version = "0.2.4")
bazel_dep(name = "abseil-cpp", version = "20250127.1")

bazel_dep(name = "googletest", version = "1.17.0", dev_dependency = True)

bazel_dep(name = "rules_rust", version = "0.68.0")
bazel_dep(name = "pcit_api", version = "0.0.0")
local_path_override(
    module_name = "pcit_api",
    path = "api",
)

bazel_dep(name = "protobuf", version = "30.2", repo_name = "com_google_protobuf")
bazel_dep(name = "rules_proto", version = "6.0.0")
bazel_dep(name = "rules_rust_prost", version = "0.68.0")
bazel_dep(name = "grpc", version = "1.78.0", repo_name = "com_github_grpc_grpc")
bazel_dep(name = "grpc-java", version = "1.71.0", repo_name = "io_grpc_grpc_java")
bazel_dep(name = "grpc-proto", version = "0.0.0-20240627-ec30f58", repo_name = "io_grpc_grpc_proto")
bazel_dep(name = "googleapis", version = "0.0.0-20251211-05f65958")
bazel_dep(name = "bazel_skylib", version = "1.8.1")
bazel_dep(name = "aspect_bazel_lib", version = "2.16.0")
bazel_dep(name = "rules_pkg", version = "1.0.1")

# Configure Rust toolchains
rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(
    edition = "2021",
    versions = ["1.87.0"],
)
use_repo(rust, "rust_toolchains")

register_toolchains("@rust_toolchains//:all")

register_toolchains("//:prost_toolchain")

crate = use_extension("@rules_rust//crate_universe:extension.bzl", "crate")
crate.annotation(
    crate = "protoc-gen-prost",
    gen_binaries = ["protoc-gen-prost"],
)
crate.annotation(
    crate = "protoc-gen-tonic",
    gen_binaries = ["protoc-gen-tonic"],
)
crate.from_cargo(
    name = "crates",
    cargo_lockfile = "//:Cargo.bazel.lock",
    manifests = [
        "//:Cargo.toml",
        "//rust/common:Cargo.toml",
    ],
)
use_repo(crate, "crates")

bazel_dep(name = "oak", version = "0.0.0")
archive_override(
    module_name = "oak",
    sha256 = "d60164481c0d815390605dc8e047ace08d6d27e751e9dacc0b31aa42bba6aba7",
    strip_prefix = "oak-38484af8f1983073be9fa62508428885827ce46d",
    url = "https://github.com/project-oak/oak/archive/38484af8f1983073be9fa62508428885827ce46d.tar.gz",
)

oak_aliased_crates = use_extension(
    "@oak//bazel/crates:extensions.bzl",
    "aliased_crates_repository",
)
use_repo(oak_aliased_crates, "oak_crates_index")
